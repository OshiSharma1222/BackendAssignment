{
  "name": "backend-assignment-api",
  "version": "1.0.0",
  "description": "Scalable REST API with JWT authentication, role-based access control, and CRUD for tasks (Node.js + Express + PostgreSQL via Prisma, Neon compatible).",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "db:seed": "node src/seed.js"
  },
  "keywords": [
    "express",
    "postgres",
    "neon",
    "prisma",
    "jwt",
    "rbac",
    "rest-api",
    "swagger"
  ],
  "author": "Backend Developer Intern",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.18.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "express-validator": "^7.2.0",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "prisma": "^5.18.0"
  },
  "engines": {
    "node": ">=18"
  }
