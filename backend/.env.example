# Server
NODE_ENV=development
PORT=5000

# Database - PostgreSQL (Neon)
# Neon gives you a pooled connection string. Use the POOLED url for the app,
# and an unpooled (direct) url for migrations if you have one.
# Example Neon URL:
# postgresql://USER:PASSWORD@ep-xxxxx-pooler.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Optional: direct (non-pooled) URL for Prisma migrate on Neon.
# If you don't have one, leave it equal to DATABASE_URL.
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# JWT
JWT_SECRET=change_this_to_a_long_random_string_at_least_32_chars
JWT_EXPIRES_IN=1d

# CORS (comma separated list of allowed origins, or * for all)
CORS_ORIGIN=http://localhost:5173

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# Seed an initial admin on first boot (used by `npm run db:seed`)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=Admin@12345
SEED_ADMIN_NAME=Admin
